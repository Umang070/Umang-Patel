
{% liquid
  assign bar_height = section.settings.bar_height | default: 64 | times: 1
  assign logo_width = section.settings.logo_width | default: 152 | times: 1
  assign button_width = section.settings.button_width | default: 207 | times: 1

  assign logo_text = section.settings.logo_text | strip
  assign logo_link = section.settings.logo_link
  assign message_text = section.settings.message_text | strip
  assign button_label = section.settings.button_label | strip
  assign button_link = section.settings.button_link

  if section.settings.enable_sticky_header == 'always'
    assign sticky = 'always'
  elsif section.settings.enable_sticky_header == 'scroll-up'
    assign sticky = 'scroll-up'
  endif
%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@400&display=swap" rel="stylesheet">

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

<header-component
  id="header-component"
  class="header color-{{ section.settings.color_scheme }}"
  data-theme-color="rgb({{ section.settings.color_scheme.settings.background.rgb }})"
  {% if sticky %}
    sticky="{{ sticky }}"
  {% endif %}
  data-skip-node-update
  data-scroll-direction="none"
  style="
    --color-scheme-top-row: rgba({{ section.settings.color_scheme.settings.background.rgba }});
    --color-scheme-bottom-row: rgba({{ section.settings.color_scheme.settings.background.rgba }});
    --brandbar-height: {{ bar_height }}px;
    --brandbar-logo-width: {{ logo_width }}px;
    --brandbar-cta-width: {{ button_width }}px;
    --brandbar-bg: {{ section.settings.header_background }};
    --brandbar-cta-bg: {{ section.settings.button_background }};
    --brandbar-cta-text: {{ section.settings.button_text_color }};
    --brandbar-message-color: {{ section.settings.message_color }};
  "
>
  <div class="header__underlay header__underlay-closed"></div>
  <div class="header__underlay header__underlay-open"></div>

  {%- if request.page_type == 'index' -%}
    <h1 class="visually-hidden">{{ shop.name }}</h1>
  {%- endif -%}

  <div
    class="header__row header__row--top color-{{ section.settings.color_scheme }} section section--full-width-margin section--{{ section.settings.section_width }}"
    ref="headerRowTop"
    style="--border-bottom-width: {{ section.settings.border_width }}px; --border-bottom-width-mobile: {{ section.settings.border_width }}px;"
  >
    <div class="brandbar spacing-style">
      <div class="brandbar__inner">

        <div class="brandbar__logo">
          {% if logo_link != blank %}
            <a class="brandbar__logo-link" href="{{ logo_link }}">
              {% if section.settings.logo_image != blank %}
                {{
                  section.settings.logo_image
                  | image_url: width: 600
                  | image_tag:
                    class: 'brandbar__logo-image',
                    loading: 'eager',
                    alt: section.settings.logo_image.alt | default: logo_text
                }}
              {% else %}
                <span class="brandbar__logo-text">{{ logo_text }}</span>
              {% endif %}
            </a>
          {% else %}
            {% if section.settings.logo_image != blank %}
              {{
                section.settings.logo_image
                | image_url: width: 600
                | image_tag:
                  class: 'brandbar__logo-image',
                  loading: 'eager',
                  alt: section.settings.logo_image.alt | default: logo_text
              }}
            {% else %}
              <span class="brandbar__logo-text">{{ logo_text }}</span>
            {% endif %}
          {% endif %}
        </div>

        <div class="brandbar__message">
          <span class="brandbar__message-text">{{ message_text }}</span>
        </div>

        <div class="brandbar__cta">
          {% if button_link != blank %}
            <a class="brandbar__cta-button" href="{{ button_link }}">
              <span class="brandbar__cta-label">{{ button_label }}</span>
              <span class="brandbar__cta-icon" aria-hidden="true">
                <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
                </svg>
              </span>
            </a>
          {% else %}
            <span class="brandbar__cta-button brandbar__cta-button--disabled">
              <span class="brandbar__cta-label">{{ button_label }}</span>
              <span class="brandbar__cta-icon" aria-hidden="true">
                <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
                </svg>
              </span>
            </span>
          {% endif %}
        </div>

      </div>

      {%- comment -%}
        Mobile layout: hamburger + logo row, followed by an expanding drawer.
        Both elements are hidden on desktop via CSS.
      {%- endcomment -%}
      <div class="brandbar__mobile-bar">
        <button
          class="brandbar__hamburger"
          type="button"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="brandbar-mobile-drawer-{{ section.id }}"
        >
          <span class="brandbar__hamburger-open" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="12" viewBox="0 0 20 12" fill="none">
              <path d="M1 6H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M1 1H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M1 11H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="brandbar__hamburger-close" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M1 1L15 15" stroke="black" stroke-width="2" stroke-linecap="round"/>
              <path d="M15 1L1 15" stroke="black" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>

        <span class="brandbar__mobile-logo-text">
          {% if section.settings.logo_image != blank %}
            {{
              section.settings.logo_image
              | image_url: width: 400
              | image_tag:
                class: 'brandbar__mobile-logo-image',
                loading: 'eager',
                alt: section.settings.logo_image.alt | default: logo_text
            }}
          {% else %}
            {{ logo_text }}
          {% endif %}
        </span>

        <span class="brandbar__hamburger-spacer" aria-hidden="true"></span>
      </div>

      <div
        class="brandbar__mobile-drawer"
        id="brandbar-mobile-drawer-{{ section.id }}"
        aria-hidden="true"
      >
        <div class="brandbar__drawer-content">
          <p class="brandbar__drawer-message">{{ message_text }}</p>
          {% if button_link != blank %}
            <a class="brandbar__drawer-cta" href="{{ button_link }}">
              <span class="brandbar__drawer-cta-label">{{ button_label }}</span>
              <span class="brandbar__drawer-cta-icon" aria-hidden="true">
                <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
                </svg>
              </span>
            </a>
          {% else %}
            <span class="brandbar__drawer-cta brandbar__drawer-cta--disabled">
              <span class="brandbar__drawer-cta-label">{{ button_label }}</span>
              <span class="brandbar__drawer-cta-icon" aria-hidden="true">
                <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
                </svg>
              </span>
            </span>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</header-component>

<script
  src="{{ 'header.js' | asset_url }}"
  type="module"
></script>

{% stylesheet %}
  body {
    --header-height: 64px;
    --header-group-height: var(--header-height);
    --transparent-header-offset-boolean: 0; /* stylelint-disable-line declaration-property-value-disallowed-list */
  }

  .header {
    --header-content-transition-timing: 0s;
    display: block;
    contain: layout style;
    background: transparent;
  }

  .header-section {
    position: relative;
    z-index: var(--layer-heightened);
  }

  #header-component {
    --submenu-height: 0px;
    --full-open-header-height: 0px;
  }

  #header-group:has(#header-component[sticky]) {
    display: contents;
  }

  .header-section:has(> #header-component[sticky='always']),
  .header-section:has(> #header-component[sticky='scroll-up'][data-sticky-state='active']) {
    position: relative;
    top: auto;
    z-index: var(--layer-heightened);
  }

  .header[data-sticky-state] {
    transition: opacity var(--animation-speed) var(--animation-easing);
    opacity: 1;
  }

  .header[data-sticky-state='idle'] {
    opacity: 0;
  }

  .header[data-sticky-state='active'] {
    view-transition-name: sticky-header;
  }

  .header__underlay {
    position: absolute;
    inset: 0;
  }

  .header__underlay-closed {
    height: 100%;
    z-index: var(--layer-lowest);
    background: var(--brandbar-bg, var(--color-scheme-top-row));
    transition: height var(--animation-speed-slow) var(--ease-out-cubic);
  }

  .header__underlay-open {
    height: var(--full-open-header-height);
    background: var(--brandbar-bg, var(--color-scheme-top-row));
    transition: height var(--submenu-animation-speed) var(--ease-out-cubic);
  }

  .header__row {
    position: relative;
    background-color: transparent;
    border-bottom: var(--border-bottom-width) solid var(--color-border);
  }

  /* ── Brand bar — desktop: [logo | message | CTA] ── */

  .brandbar {
    height: var(--brandbar-height);
    display: flex;
    align-items: center;
    --padding-block-start: 0px;
    --padding-block-end: 0px;
  }

  /* Three equal columns: logo left, message centred, CTA right */
  .brandbar__inner {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr minmax(0, auto) 1fr;
    align-items: center;
    column-gap: var(--gap-xl);
  }

  .brandbar__logo {
    justify-self: start;
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .brandbar__logo-link {
    display: inline-flex;
    align-items: center;
    color: inherit;
    text-decoration: none;
    transition: opacity var(--animation-speed) var(--animation-easing),
      transform var(--animation-speed) var(--animation-easing);
    will-change: opacity, transform;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .brandbar__logo-link:hover {
      opacity: 0.8;
      transform: translateY(-1px);
    }
  }

  .brandbar__logo-image {
    width: var(--brandbar-logo-width);
    height: auto;
    max-height: calc(var(--brandbar-height) - 24px);
    object-fit: contain;
    object-position: left center;
    display: block;
  }

  .brandbar__logo-text {
    display: inline-flex;
    align-items: center;
    width: var(--brandbar-logo-width);
    height: auto;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0;
    white-space: nowrap;
  }

  /* ── Center message ── */
  .brandbar__message {
    justify-self: center;
    min-width: 0;
    color: var(--brandbar-message-color);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .brandbar__message-text {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 16px;
    line-height: 1.2;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── CTA button ── */
  .brandbar__cta {
    justify-self: end;
    display: flex;
    align-items: center;
  }

  .brandbar__cta-button {
    width: var(--brandbar-cta-width);
    height: auto;
    padding-block: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    background: var(--brandbar-cta-bg);
    border: none;
    color: var(--brandbar-cta-text);
    text-decoration: none;
    cursor: pointer;
    user-select: none;
    transition:
      transform var(--animation-speed) var(--animation-easing),
      background-color var(--animation-speed) var(--animation-easing),
      color var(--animation-speed) var(--animation-easing);
    will-change: transform;
  }

  .brandbar__cta-label {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 16px;
    line-height: 20.48px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
  }

  .brandbar__cta-icon {
    width: 29px;
    height: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform var(--animation-speed) var(--animation-easing);
  }

  .brandbar__cta-icon svg {
    width: 29px;
    height: 12px;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .brandbar__cta-button:hover {
      transform: translateY(-1px);
    }

    .brandbar__cta-button:hover .brandbar__cta-icon {
      transform: translateX(3px);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .brandbar__inner {
      animation: brandbarIn 420ms var(--ease-out-cubic, cubic-bezier(0.33, 1, 0.68, 1)) both;
    }

    @keyframes brandbarIn {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }

  /* Mobile-specific elements are hidden on desktop */
  .brandbar__mobile-bar,
  .brandbar__mobile-drawer {
    display: none;
  }

  /* ── Mobile layout ──────────────────────────────────────────────────────────
   * The desktop 3-column inner bar is hidden. A simplified bar replaces it:
   *   [hamburger | logo (centred) | spacer]
   * Tapping the hamburger expands a drawer below the bar by animating its
   * height from 0 to scrollHeight, pushing page content down naturally.
   * ─────────────────────────────────────────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    /* Height is auto so the bar can grow when the drawer is open */
    .brandbar {
      height: auto;
      flex-direction: column;
      align-items: stretch;
    }

    .brandbar__inner {
      display: none;
    }

    /* Three-column bar: equal-width icon columns keep the logo perfectly centred */
    .brandbar__mobile-bar {
      display: grid;
      grid-template-columns: 44px 1fr 44px;
      align-items: center;
      height: var(--brandbar-height);
      padding-inline: 16px;
      box-shadow: 0px 2px 4px 0px transparent;
      transition: box-shadow 0.55s cubic-bezier(0.22, 1, 0.36, 1);
      z-index: 999;
    }

    .brandbar.is-open .brandbar__mobile-bar {
      box-shadow: 0px 2px 4px 0px #00000026;
    }

    /* ── Hamburger / close toggle ── */
    .brandbar__hamburger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      padding: 0;
      border: none;
      background: transparent;
      cursor: pointer;
      color: inherit;
      -webkit-tap-highlight-color: transparent;
    }

    .brandbar__hamburger-open,
    .brandbar__hamburger-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .brandbar__hamburger-close {
      display: none;
    }

    .brandbar.is-open .brandbar__hamburger-open {
      display: none;
    }

    .brandbar.is-open .brandbar__hamburger-close {
      display: inline-flex;
    }

    .brandbar__mobile-logo-text {
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      font-weight: 700;
      font-size: 20px;
      letter-spacing: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brandbar__mobile-logo-image {
      height: calc(var(--brandbar-height) - 24px);
      width: auto;
      max-width: 180px;
      object-fit: contain;
      display: block;
    }

    .brandbar__hamburger-spacer {
      width: 44px;
    }

    /* ── Expanding drawer ──────────────────────────────────────────────────────
     * Height is animated from 0 → scrollHeight via JavaScript, so the browser
     * can perform a hardware-accelerated layout animation without fixed heights.
     * ─────────────────────────────────────────────────────────────────────────── */
    .brandbar__mobile-drawer {
      display: block;
      height: 0;
      overflow: hidden;
      transition: height 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    }


    .brandbar__drawer-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      padding: 24px 20px 32px;
      text-align: center;
      background-color: #f2f2f2;
    }

    .brandbar__drawer-message {
      font-family: 'Jost', sans-serif;
      font-weight: 400;
      font-size: 16px;
      line-height: 1.4;
      letter-spacing: 0;
      color: var(--brandbar-message-color, inherit);
      margin: 0;
    }

    .brandbar__drawer-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding-block: 14px;
      padding-inline: 24px;
      background: var(--brandbar-cta-bg);
      color: var(--brandbar-cta-text);
      text-decoration: none;
      cursor: pointer;
      transition: transform 0.2s ease;
    }

    .brandbar__drawer-cta-label {
      font-family: 'Jost', sans-serif;
      font-weight: 400;
      font-size: 16px;
      line-height: 20.48px;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    .brandbar__drawer-cta-icon {
      width: 29px;
      height: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: transform 0.2s ease;
    }

    @media (hover: hover) {
      .brandbar__drawer-cta:hover {
        transform: translateY(-1px);
      }

      .brandbar__drawer-cta:hover .brandbar__drawer-cta-icon {
        transform: translateX(3px);
      }
    }
  }
{% endstylesheet %}

{% unless request.design_mode %}
  <script type="module">
    import { hydrate } from '@theme/section-hydration';
    const url = new URL(window.location.href);
    url.searchParams.delete('page');
    hydrate('{{ section.id }}', url);
  </script>
{% endunless %}

<script>
(function () {
  function initMobileMenu() {
    var brandbar  = document.querySelector('.brandbar');
    var hamburger = document.querySelector('.brandbar__hamburger');
    var drawer    = document.getElementById('brandbar-mobile-drawer-{{ section.id }}');
    if (!brandbar || !hamburger || !drawer) return;

    function openMenu() {
      brandbar.classList.add('is-open');
      hamburger.setAttribute('aria-expanded', 'true');
      drawer.setAttribute('aria-hidden', 'false');
      // Measure actual content height so the CSS transition animates to the exact target
      var inner = drawer.querySelector('.brandbar__drawer-content');
      drawer.style.height = (inner ? inner.scrollHeight : 160) + 'px';
    }

    function closeMenu() {
      brandbar.classList.remove('is-open');
      hamburger.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
      drawer.style.height = '0';
    }

    hamburger.addEventListener('click', function () {
      if (brandbar.classList.contains('is-open')) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && brandbar.classList.contains('is-open')) {
        closeMenu();
        hamburger.focus();
      }
    });

    // Reset state when the viewport is resized back to desktop
    var mq = window.matchMedia('(min-width: 750px)');
    function onBreakpoint(e) {
      if (e.matches) closeMenu();
    }
    if (mq.addEventListener) {
      mq.addEventListener('change', onBreakpoint);
    } else {
      mq.addListener(onBreakpoint); // Safari < 14 fallback
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu);
  } else {
    initMobileMenu();
  }
})();
</script>

