{%- comment -%}
  ============================================================================
  SECTION: Hero Brand  (sections/hero-brand.liquid)
  ============================================================================
  
  Layout:
    Desktop — CSS grid overlay: image fills the section height, title +
              subtitle + CTA are pinned to the bottom-left of the same cell.
    Mobile  — Flexbox column: title and subtitle render above the image;
              the CTA button is absolutely positioned over the image bottom.

  Key features:
    • Separate desktop and mobile images (mobile image overrides on ≤749 px).
    • Separate desktop and mobile rich-text subtitles.
    • CTA button duplicated in HTML: one inside .hero-brand__content (desktop),
      one inside .hero-brand__media (mobile on-image placement).
    • Bottom ticker bar with configurable text, background and text colour.

  Schema settings:
    Content  — heading, subtitle (richtext), mobile subtitle (richtext)
    Button   — label, link, background colour, text colour
    Image    — desktop image picker, mobile image picker
    Bottom bar — ticker text, background colour, text colour
    Appearance — section background, text colour
  ============================================================================
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500&display=swap" rel="stylesheet">

<section
  class="hero-brand"
  style="
    --hero-bg: {{ section.settings.background_color }};
    --hero-text: {{ section.settings.text_color }};
    --hero-btn-bg: {{ section.settings.button_background }};
    --hero-btn-text: {{ section.settings.button_text_color }};
    --hero-ticker-bg: {{ section.settings.ticker_background }};
    --hero-ticker-text: {{ section.settings.ticker_text_color }};
  "
>
  <div class="hero-brand__body">

    {%- assign mobile_image = section.settings.mobile_image -%}
    {%- assign desktop_image = section.settings.image -%}

    {%- comment -%}
      Desktop: title, subtitle and CTA overlay the image (bottom-left).
      On mobile these are reordered above the image via flexbox order.
    {%- endcomment -%}
    <div class="hero-brand__content">
      <h2 class="hero-brand__heading">{{ section.settings.heading }}</h2>
      <div class="hero-brand__subtitle hero-brand__subtitle--desktop">{{ section.settings.subtitle }}</div>
      {%- if section.settings.mobile_subtitle != blank -%}
        <div class="hero-brand__subtitle hero-brand__subtitle--mobile">{{ section.settings.mobile_subtitle }}</div>
      {%- endif -%}

      {% if section.settings.button_label != blank %}
        <a
          class="hero-brand__btn hero-brand__btn--desktop"
          href="{{ section.settings.button_link | default: '#' }}"
        >
          <span class="hero-brand__btn-label">{{ section.settings.button_label }}</span>
          <span class="hero-brand__btn-icon" aria-hidden="true">
            <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
            </svg>
          </span>
        </a>
      {% endif %}
    </div>

    {%- comment -%}
      Background image. On mobile the CTA button is rendered inside this
      wrapper so it can be absolutely positioned over the image.
    {%- endcomment -%}
    <div class="hero-brand__media">
      {% if desktop_image != blank %}
        {{
          desktop_image
          | image_url: width: 2000
          | image_tag:
            class: 'hero-brand__image hero-brand__image--desktop',
            loading: 'eager',
            alt: '',
            sizes: '100vw'
        }}
      {% else %}
        <div class="hero-brand__image-placeholder hero-brand__image--desktop">
          {{ 'image' | placeholder_svg_tag: 'hero-brand__placeholder-svg' }}
        </div>
      {% endif %}

      {% if mobile_image != blank %}
        {{
          mobile_image
          | image_url: width: 800
          | image_tag:
            class: 'hero-brand__image hero-brand__image--mobile',
            loading: 'eager',
            alt: '',
            sizes: '100vw'
        }}
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          class="hero-brand__btn hero-brand__btn--on-image"
          href="{{ section.settings.button_link | default: '#' }}"
        >
          <span class="hero-brand__btn-label">{{ section.settings.button_label }}</span>
          <span class="hero-brand__btn-icon" aria-hidden="true">
            <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
            </svg>
          </span>
        </a>
      {% endif %}
    </div>

  </div>

  {% if section.settings.ticker_text != blank %}
    <div class="hero-brand__ticker">
      <span class="hero-brand__ticker-text">{{ section.settings.ticker_text }}</span>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .hero-brand {
    background: var(--hero-bg);
    color: var(--hero-text);
    display: flex;
    flex-direction: column;
    width: 100%;
    overflow: hidden;
  }

  /*
   * Both .hero-brand__media and .hero-brand__content share the same named
   * grid area "hero", so the content layer overlays the image. The image
   * stays in normal document flow, making the section height image-driven.
   */
  .hero-brand__body {
    display: grid;
    grid-template-areas: "hero";
  }

  .hero-brand__media {
    grid-area: hero;
    width: 100%;
    overflow: hidden;
  }

  .hero-brand__content {
    grid-area: hero;
    position: relative;
    z-index: 1;
    align-self: end;
    display: flex;
    flex-direction: column;
    padding: 48px 0px 56px 60px;
    gap: 24px;
    max-width: 800px;
  }

  .hero-brand__heading {
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    font-style: normal;
    font-size: 70px;
    line-height: 100%;
    letter-spacing: 0px;
    vertical-align: middle;
    margin: 0;
    color: var(--hero-text);
  }

  .hero-brand__subtitle {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 20px;
    line-height: 140%;
    letter-spacing: 0px;
    vertical-align: middle;
    color: var(--hero-text);
    max-width: 380px;
  }

  .hero-brand__subtitle p,
  .hero-brand__subtitle ul,
  .hero-brand__subtitle ol {
    margin: 0;
  }

  .hero-brand__subtitle p + p {
    margin-top: 0.75em;
  }

  .hero-brand__subtitle a {
    color: var(--hero-text);
    text-decoration: underline;
  }

  .hero-brand__subtitle strong {
    font-weight: 600;
  }

  /* ── CTA button ── */
  .hero-brand__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: var(--hero-btn-bg);
    color: var(--hero-btn-text);
    text-decoration: none;
    padding: 14px 28px;
    width: fit-content;
    border: none;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
    will-change: transform;
  }

  .hero-brand__btn-label {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 16px;
    line-height: 20.48px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
  }

  .hero-brand__btn-icon {
    width: 29px;
    height: 12px;
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .hero-brand__btn-icon svg {
    width: 29px;
    height: 12px;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .hero-brand__btn:hover {
      transform: translateY(-2px);
      opacity: 0.92;
    }

    .hero-brand__btn:hover .hero-brand__btn-icon {
      transform: translateX(4px);
    }
  }

  /*
   * On mobile the button is centred via left:50% + translateX(-50%).
   * The desktop hover rule sets transform:translateY(-2px) which replaces
   * that centering transform and causes the button to jump/shift.
   * This override restores translateX(-50%) on hover to keep the button
   * centred while suppressing the vertical movement.
   */
  @media (hover: hover) and (max-width: 749px) {
    .hero-brand__btn.hero-brand__btn--on-image:hover {
      transform: translateX(-50%);
      opacity: 1;
    }

    .hero-brand__btn.hero-brand__btn--on-image:hover .hero-brand__btn-icon {
      transform: none;
    }
  }

  .hero-brand__image {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-brand__image-placeholder {
    width: 100%;
    height: 100%;
    background: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-brand__placeholder-svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  /* ── Bottom ticker bar ── */
  .hero-brand__ticker {
    background: var(--hero-ticker-bg);
    color: var(--hero-ticker-text);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: 12px;
    width: 100%;
  }

  .hero-brand__ticker-text {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 16px;
    line-height: 13.42px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Mobile-only elements are hidden on desktop */
  .hero-brand__image--mobile,
  .hero-brand__btn--on-image,
  .hero-brand__subtitle--mobile {
    display: none;
  }

  /* ── Mobile layout ─────────────────────────────────────────────────────────
   * Switches from the desktop grid-overlay to a flex column:
   *   1. Content block (title + subtitle) — order: 1  → rendered above image
   *   2. Media block (image + on-image CTA) — order: 2 → rendered below
   * ────────────────────────────────────────────────────────────────────────── */
  @media screen and (max-width: 749px) {

    .hero-brand__body {
      display: flex;
      flex-direction: column;
    }

    .hero-brand__content {
      order: 1;
      position: static;
      z-index: auto;
      align-self: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 32px 24px 12px;
      gap: 24px;
      max-width: 100%;
    }

    /* Desktop CTA is hidden; the on-image duplicate inside .hero-brand__media
       is shown instead so it can be absolutely positioned over the image. */
    .hero-brand__btn--desktop {
      display: none;
    }

    .hero-brand__media {
      order: 2;
      position: relative; /* establishes containing block for the on-image button */
      width: 100%;
    }

    .hero-brand__heading {
      font-size: 30px;
      font-weight: 500;
      line-height: 100%;
      letter-spacing: 0;
      text-align: center;
    }

    /* If a mobile-specific subtitle is set, the desktop one is hidden via :has() */
    .hero-brand__subtitle {
      font-size: 16px;
      line-height: 130%;
      letter-spacing: 0;
      text-align: center;
      max-width: 100%;
    }

    .hero-brand__subtitle--mobile {
      display: block;
    }

    .hero-brand:has(.hero-brand__subtitle--mobile) .hero-brand__subtitle--desktop {
      display: none;
    }

    .hero-brand__image--mobile {
      display: block;
    }

    /* If a mobile image is set, hide the desktop image on mobile */
    .hero-brand:has(.hero-brand__image--mobile) .hero-brand__image--desktop {
      display: none;
    }

    /* CTA centred near the bottom of the image — all animations disabled on mobile */
    .hero-brand__btn--on-image,
    .hero-brand__btn--on-image .hero-brand__btn-icon {
      transition: none;
    }

  

    .hero-brand__btn--on-image {
      display: inline-flex;
      position: absolute;
      bottom: 39px;
      left: 50%;
      transform: translateX(-50%);
      white-space: nowrap;
    }

    .hero-brand__ticker-text {
      font-size: 14px;
      line-height: 13.42px;
      white-space: normal;
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero brand",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "richtext",
      "id": "mobile_subtitle",
      "label": "Subtitle (mobile)",
      "info": "Overrides the subtitle on mobile. Leave blank to use the default subtitle."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Image (mobile)",
      "info": "Overrides the image on mobile. Leave blank to use the default image."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "ticker_text",
      "label": "Bottom bar text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "color",
      "id": "ticker_background",
      "label": "Bottom bar background",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "ticker_text_color",
      "label": "Bottom bar text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    }
  ],
  "presets": [
    {
      "name": "Hero brand"
    }
  ]
}
{% endschema %}
