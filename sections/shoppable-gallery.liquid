{%- comment -%}
  ============================================================================
  SECTION: Shoppable Gallery  (sections/shoppable-gallery.liquid)
  ============================================================================

  Layout:
    Desktop — configurable N-column grid (2–4 cols) with custom image height
              and gap; grid items fade + slide up on scroll (row by row).
    Mobile  — forced 2-column grid with independent image height and gap
              settings. Pin positions can also be set per-block for mobile.

  Quick-view modal:
    • Product data is fetched via Shopify's /products/handle.js AJAX API.
    • All products are prefetched when the section enters the viewport
      (400 px root margin) to eliminate loading delays on pin click.
    • Colour variants use a sliding highlight indicator.
    • Size variants use a custom animated dropdown (max 3 options visible,
      scrollable beyond that).
    • On add-to-cart success: shows "ADDED!" for 700 ms, then closes the
      modal (or redirects to /cart if the setting is enabled).

  Auto-bundle rule:
    When a variant matching the configured trigger colour AND trigger size is
    added to cart, a second bundle variant ID is automatically included in
    the same cart/add.js request. Matching is fuzzy (case-insensitive,
    starts-with) so "M" matches "Medium" and vice-versa.

  Schema settings (section):
    Grid     — heading, columns, image height, gap (desktop + mobile)
    Cart     — redirect to cart checkbox
    Bundle   — trigger colour, trigger size, bundle variant ID
    Appearance — background colour, heading colour

  Schema settings (block — per product):
    Product        — product picker, optional custom image override
    Pin position   — X/Y % sliders for desktop and mobile independently
  ============================================================================
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&family=Lustria&display=swap" rel="stylesheet">

<section
  class="sg"
  data-redirect-to-cart="{{ section.settings.redirect_to_cart }}"
  data-bundle-trigger-color="{{ section.settings.bundle_trigger_color | downcase | strip }}"
  data-bundle-trigger-size="{{ section.settings.bundle_trigger_size | downcase | strip }}"
  data-bundle-variant-id="{{ section.settings.bundle_variant_id | strip }}"
  style="
    --sg-bg: {{ section.settings.background_color }};
    --sg-text: {{ section.settings.text_color }};
    --sg-gap: {{ section.settings.grid_gap }}px;
    --sg-gap-mobile: {{ section.settings.mobile_grid_gap }}px;
    --sg-img-height-mobile: {{ section.settings.mobile_image_height }}px;
    --sg-cols: {{ section.settings.columns }};
    --sg-img-height: {{ section.settings.image_height }}px;
  "
>
  {% if section.settings.heading != blank %}
    <h2 class="sg__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="sg__grid" id="sg-grid-{{ section.id }}">
    {% for block in section.blocks %}
      {% assign col_count = section.settings.columns | plus: 0 %}
      {% assign row = forloop.index0 | divided_by: col_count | floor %}
      <div
        class="sg__item"
        data-row="{{ row }}"
        {{ block.shopify_attributes }}
      >
        {%- assign product = block.settings.product -%}
        {%- assign display_image = block.settings.custom_image | default: product.featured_image -%}

        {% if display_image != blank %}
          {{
            display_image
            | image_url: width: 800
            | image_tag:
              class: 'sg__img',
              loading: 'lazy',
              alt: display_image.alt | default: product.title,
              sizes: '(max-width: 749px) 100vw, 33vw'
          }}
        {% else %}
          <div class="sg__img-placeholder">
            {{ 'image' | placeholder_svg_tag: 'sg__placeholder-svg' }}
          </div>
        {% endif %}

        {% if product != blank %}
          <button
            class="sg__pin"
            type="button"
            data-handle="{{ product.handle }}"
            aria-label="Quick view {{ product.title }}"
            style="left: {{ block.settings.pin_x }}%; top: {{ block.settings.pin_y }}%; --pin-x-mobile: {{ block.settings.mobile_pin_x }}%; --pin-y-mobile: {{ block.settings.mobile_pin_y }}%;"
          >
        {% else %}
          <span
            class="sg__pin"
            aria-hidden="true"
            style="left: {{ block.settings.pin_x }}%; top: {{ block.settings.pin_y }}%; --pin-x-mobile: {{ block.settings.mobile_pin_x }}%; --pin-y-mobile: {{ block.settings.mobile_pin_y }}%;"
          >
        {% endif %}
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M4.98047 0.75V9.21154" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
            <path d="M0.75 4.98077H9.21154" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
          </svg>
        {% if product != blank %}
          </button>
        {% else %}
          </span>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <div class="sg-qv" id="sg-qv-{{ section.id }}" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Quick view">
    <div class="sg-qv__backdrop"></div>
    <div class="sg-qv__card">
      <button class="sg-qv__close" type="button" aria-label="Close">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1L11 11M11 1L1 11" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      <div class="sg-qv__top">
        <div class="sg-qv__img-wrap">
          <img class="sg-qv__img" src="" alt="" width="100" height="100">
        </div>
        <div class="sg-qv__info">
          <p class="sg-qv__title"></p>
          <p class="sg-qv__price"></p>
          <p class="sg-qv__desc"></p>
        </div>
      </div>

      <div class="sg-qv__options"></div>

      <div class="sg-qv__footer">
        <button class="sg-qv__atc" type="button" disabled>
          <span class="sg-qv__atc-label">ADD TO CART</span>
          <span class="sg-qv__atc-icon" aria-hidden="true">
            <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
            </svg>
          </span>
        </button>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .sg {
    background: var(--sg-bg);
    color: var(--sg-text);
    width: 100%;
  }

  .sg__heading {
    font-family: 'Lustria', serif;
    font-weight: 400;
    font-style: normal;
    font-size: 36px;
    line-height: 120%;
    letter-spacing: 0px;
    vertical-align: middle;
    margin: 0;
    padding: 32px 50px 30px 50px;
    color: var(--sg-text);
  }

  /* ── Grid ── */
  .sg__grid {
    display: grid;
    grid-template-columns: repeat(var(--sg-cols), 1fr);
    gap: var(--sg-gap);
    padding-inline: 50px;
  }

  /* ── Each item ── */
  .sg__item {
    position: relative;
    overflow: hidden;
    display: block;
    line-height: 0;
    height: var(--sg-img-height);
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .sg__item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .sg__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .sg__img-placeholder {
    width: 100%;
    height: 100%;
    background: #e8e8e8;
  }

  .sg__placeholder-svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  /* ── Plus pin ── */
  .sg__pin {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #F8F8F8E5;
    box-shadow: 0px 3px 4px 0px #00000033;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex-shrink: 0;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    border: none;
    padding: 0;
  }

  @media (hover: hover) {
    .sg__pin:hover {
      transform: translate(-50%, -50%) scale(1.15);
      box-shadow: 0px 5px 8px 0px #00000044;
    }
  }

  /* ── Quick-view modal ── */
  .sg-qv {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .sg-qv.is-open {
    display: flex;
  }

  /* ── Backdrop ── */
  .sg-qv__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
    cursor: pointer;
    opacity: 0;
    animation: sgBackdropIn 0.35s ease forwards;
  }

  .sg-qv.is-closing .sg-qv__backdrop {
    animation: sgBackdropOut 0.22s ease forwards;
  }

  @keyframes sgBackdropIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes sgBackdropOut {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  /* ── Card ── */
  .sg-qv__card {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 311px;
    padding: 35px 20px 20px;
    display: flex;
    flex-direction: column;
    max-height: 90vh;
    overflow-y: auto;
    opacity: 0;
    transform: translateY(28px) scale(0.97);
    animation: sgCardIn 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .sg-qv.is-closing .sg-qv__card {
    animation: sgCardOut 0.22s cubic-bezier(0.55, 0, 1, 0.45) forwards;
  }

  @keyframes sgCardIn {
    from { opacity: 0; transform: translateY(28px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes sgCardOut {
    from { opacity: 1; transform: translateY(0) scale(1); }
    to   { opacity: 0; transform: translateY(20px) scale(0.97); }
  }

  /* ── Close button ── */
  .sg-qv__close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  /* ── Top row: thumbnail + product info ── */
  .sg-qv__top {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
    align-items: flex-start;
  }

  .sg-qv__img-wrap {
    flex-shrink: 0;
    width: 120px;
    height: 155px;
    overflow: hidden;
    background: #f5f5f5;
  }

  .sg-qv__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .sg-qv__info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .sg-qv__title {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-style: normal;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0px;
    vertical-align: middle;
    margin: 0;
    color: #1a1a1a;
  }

  .sg-qv__price {
    font-family: 'Lustria', serif;
    font-weight: 400;
    font-style: normal;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0px;
    vertical-align: middle;
    margin: 0;
    color: #1a1a1a;
  }

  .sg-qv__desc {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-style: normal;
    font-size: 14px;
    line-height: 110%;
    letter-spacing: -0.01em;
    vertical-align: middle;
    margin: 0;
    color: #555;
    max-height: 94px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
  }

  /* ── Variant options ── */
  .sg-qv__options {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sg-qv__option-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sg-qv__option-label {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 13px;
    line-height: 1;
    color: #1a1a1a;
    text-transform: capitalize;
    margin: 0;
  }

  /* ── Colour variant selector ── */
  .sg-qv__color-row {
    position: relative;
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
  }

  /* The sliding selection indicator */
  .sg-qv__color-slider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 0;
    background: #1a1a1a;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    /* transitions set dynamically by JS */
  }

  .sg-qv__color-btn {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 18px;
    line-height: 100%;
    letter-spacing: -0.02em;
    text-transform: capitalize;
    flex: 1 1 0;
    padding: 14px 16px;
    background: transparent;
    color: #1a1a1a;
    border: 1px solid #d0d0d0;
    border-left: 4px solid var(--swatch, #d0d0d0);
    cursor: pointer;
    position: relative;
    z-index: 1;
    transition: color 0.2s ease;
  }

  .sg-qv__color-btn + .sg-qv__color-btn {
    border-left: 4px solid var(--swatch, #d0d0d0);
  }

  .sg-qv__color-btn.is-selected {
    color: #fff;
  }

  /* ── Size variant selector (custom dropdown) ── */
  .sg-qv__size-wrap {
    position: relative;
    user-select: none;
    margin-bottom: 50px;
  }

  .sg-qv__size-trigger {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 16px;
    line-height: 100%;
    letter-spacing: -0.02em;
    vertical-align: middle;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0;
    padding-left: 16px;
    border: 1px solid #d0d0d0;
    background: #fff;
    color: #1a1a1a;
    cursor: pointer;
    text-align: left;
    gap: 0;
  }

  .sg-qv__size-trigger-text {
    flex: 1;
    padding-block: 14px;
    text-align: left;
    transition: opacity 0.15s ease;
  }

  .sg-qv__size-trigger-text.is-selected {
    text-align: center;
  }

  .sg-qv__size-chevron {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    align-self: stretch;
    border-left: 1px solid #d0d0d0;
    transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
    color: #1a1a1a;
  }

  .sg-qv__size-wrap.is-open .sg-qv__size-chevron {
    transform: rotate(180deg);
  }

  .sg-qv__size-list {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #fff;
    border: 1px solid #d0d0d0;
    border-top: none;
    z-index: 20;
    max-height: calc(3 * 49px);
    overflow-y: auto;
    overflow-x: hidden;
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
    scrollbar-width: thin;
    scrollbar-color: #d0d0d0 transparent;
  }

  .sg-qv__size-list::-webkit-scrollbar {
    width: 4px;
  }
  .sg-qv__size-list::-webkit-scrollbar-track {
    background: transparent;
  }
  .sg-qv__size-list::-webkit-scrollbar-thumb {
    background: #d0d0d0;
  }

  .sg-qv__size-wrap.is-open .sg-qv__size-list {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .sg-qv__size-opt {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1;
    width: 100%;
    padding: 14px 16px;
    text-align: center;
    background: #fff;
    color: #1a1a1a;
    border: none;
    border-top: 1px solid #f0f0f0;
    cursor: pointer;
    display: block;
    transition: background 0.18s ease, color 0.18s ease;
  }

  .sg-qv__size-opt:first-child {
    border-top: none;
  }

  .sg-qv__size-opt:hover,
  .sg-qv__size-opt.is-selected {
    background: #1a1a1a;
    color: #fff;
  }

  /* ── Add-to-cart footer ── */
  .sg-qv__footer {
    margin-top: 4px;
  }

  .sg-qv__atc {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 14px 28px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .sg-qv__atc:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .sg-qv__atc-label {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 20.48px;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .sg-qv__atc-icon {
    display: inline-flex;
    align-items: center;
    transition: transform 0.2s ease;
  }

  @media (hover: hover) {
    .sg-qv__atc:not(:disabled):hover .sg-qv__atc-icon {
      transform: translateX(4px);
    }
  }

  .sg-qv__atc-label.is-added {
    letter-spacing: 0.02em;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .sg-qv__img-wrap {
      height: 140px;
    }

    .sg__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--sg-gap-mobile);
      padding-inline: 16px;
    }

    .sg__item {
      height: var(--sg-img-height-mobile);
    }

    .sg__pin {
      left: var(--pin-x-mobile) !important;
      top:  var(--pin-y-mobile) !important;
    }

    .sg__heading {
      font-family: 'Lustria', serif;
      font-weight: 400;
      font-size: 24px;
      line-height: 120%;
      letter-spacing: 0px;
      vertical-align: middle;
      text-align: center;
      padding: 40px 16px 20px;
    }

    .sg-qv__card {
      max-width: 100%;
      margin: 16px;
      padding: 24px 20px 25px;
    }
  }
{% endstylesheet %}

<script>
(function () {
  const grid  = document.getElementById('sg-grid-{{ section.id }}');
  const modal = document.getElementById('sg-qv-{{ section.id }}');
  const sgSection = grid && grid.closest('.sg');
  if (!grid || !modal || !sgSection) return;

  const moneyFormat         = {{ shop.money_format | json }};
  const redirectToCart      = sgSection.dataset.redirectToCart === 'true';
  const bundleTriggerColor  = sgSection.dataset.bundleTriggerColor;
  const bundleTriggerSize   = sgSection.dataset.bundleTriggerSize;
  const bundleVariantId     = sgSection.dataset.bundleVariantId;

  /* ── Scroll reveal ── */
  const items = Array.from(grid.querySelectorAll('.sg__item'));
  const rowMap = {};
  items.forEach(function (el) {
    const row = el.dataset.row;
    if (!rowMap[row]) rowMap[row] = [];
    rowMap[row].push(el);
  });
  const rows = Object.keys(rowMap).sort(function (a, b) { return a - b; });
  rows.forEach(function (row) {
    rowMap[row].forEach(function (el, colIdx) {
      el.style.transitionDelay = (colIdx * 0.08) + 's';
    });
  });
  // Only reveal a row when it actually enters the viewport from below
  const revealObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (!entry.isIntersecting) return;
      const row = entry.target.dataset.row;
      if (rowMap[row]) {
        rowMap[row].forEach(function (el) { el.classList.add('is-visible'); });
      }
      revealObserver.unobserve(entry.target);
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  rows.forEach(function (row) { revealObserver.observe(rowMap[row][0]); });

  /* ── Modal state ── */
  let currentProduct = null;
  let selectedOptions = {};
  let currentVariant = null;

  const elImg    = modal.querySelector('.sg-qv__img');
  const elTitle  = modal.querySelector('.sg-qv__title');
  const elPrice  = modal.querySelector('.sg-qv__price');
  const elDesc   = modal.querySelector('.sg-qv__desc');
  const elOpts   = modal.querySelector('.sg-qv__options');
  const elAtc    = modal.querySelector('.sg-qv__atc');
  const elAtcLbl = modal.querySelector('.sg-qv__atc-label');

  function formatMoney(cents) {
    try {
      if (typeof Shopify !== 'undefined' && typeof Shopify.formatMoney === 'function') {
        return Shopify.formatMoney(cents, moneyFormat);
      }
    } catch (e) {}

    // Manual fallback — apply moneyFormat substitutions in longest-match order
    var fmt     = moneyFormat || '{{amount}}';
    var amount  = (cents / 100).toFixed(2);
    var amtComma       = amount.replace('.', ',');
    var amtNoDec       = String(Math.floor(cents / 100));
    var amtNoDecComma  = amtNoDec;

    return fmt
      .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/g, amtNoDecComma)
      .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g,             amtComma)
      .replace(/\{\{\s*amount_no_decimals\s*\}\}/g,                      amtNoDecComma)
      .replace(/\{\{\s*amount\s*\}\}/g,                                  amount);
  }

  // Shopify /products/handle.js returns options as objects: {name, position, values[]}
  function optionName(opt) {
    return typeof opt === 'string' ? opt : opt.name;
  }
  function optionValues(opt, idx) {
    if (opt.values && opt.values.length) return opt.values;
    return [...new Set(currentProduct.variants.map(function (v) {
      return v['option' + (idx + 1)];
    }))];
  }

  function findVariant() {
    if (!currentProduct) return null;
    return currentProduct.variants.find(function (v) {
      return currentProduct.options.every(function (opt, i) {
        return v['option' + (i + 1)] === selectedOptions[optionName(opt)];
      });
    }) || null;
  }

  function updateAtcState() {
    currentVariant = findVariant();
    const allSelected = currentProduct.options.every(function (opt) {
      return selectedOptions[optionName(opt)];
    });
    elAtc.disabled = !allSelected || !currentVariant || !currentVariant.available;
    elAtcLbl.textContent = (currentVariant && !currentVariant.available) ? 'SOLD OUT' : 'ADD TO CART';
  }

  function renderOptions() {
    elOpts.innerHTML = '';
    if (!currentProduct || !currentProduct.options || currentProduct.options.length === 0) return;

    // Skip the dummy "Title" option on single-variant products
    // Sort so colour options always render before size/other options
    const opts = currentProduct.options
      .filter(function (opt) { return optionName(opt) !== 'Title'; })
      .sort(function (a, b) {
        const isColorA = /colou?r/i.test(optionName(a)) ? 0 : 1;
        const isColorB = /colou?r/i.test(optionName(b)) ? 0 : 1;
        return isColorA - isColorB;
      });
    if (opts.length === 0) return;

    opts.forEach(function (opt, optIdx) {
      const name   = optionName(opt);
      const values = optionValues(opt, optIdx);

      const group = document.createElement('div');
      group.className = 'sg-qv__option-group';

      const label = document.createElement('p');
      label.className = 'sg-qv__option-label';
      label.textContent = name;
      group.appendChild(label);

      const isColor = /colou?r/i.test(name);

      if (isColor) {
        const row = document.createElement('div');
        row.className = 'sg-qv__color-row';

        const slider = document.createElement('div');
        slider.className = 'sg-qv__color-slider';
        row.appendChild(slider);

        let sliderVisible = false;

        function placeSlider(btn) {
          slider.style.transition = 'none';
          slider.style.left  = btn.offsetLeft + 'px';
          slider.style.width = btn.offsetWidth + 'px';
        }

        function fadeInSlider(btn) {
          // Snap to position first, then fade in
          placeSlider(btn);
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              slider.style.transition = 'opacity 0.22s ease';
              slider.style.opacity = '1';
              sliderVisible = true;
            });
          });
        }

        function slideSlider(btn) {
          slider.style.transition = 'left 0.5s cubic-bezier(0.22, 1, 0.36, 1), width 0.5s cubic-bezier(0.22, 1, 0.36, 1)';
          slider.style.left  = btn.offsetLeft + 'px';
          slider.style.width = btn.offsetWidth + 'px';
        }

        values.forEach(function (val) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'sg-qv__color-btn';
          btn.textContent = val;
          btn.style.setProperty('--swatch', val.toLowerCase());
          if (selectedOptions[name] === val) btn.classList.add('is-selected');
          btn.addEventListener('click', function () {
            selectedOptions[name] = val;
            row.querySelectorAll('.sg-qv__color-btn').forEach(function (b) {
              b.classList.toggle('is-selected', b.textContent === val);
            });
            if (!sliderVisible) {
              fadeInSlider(btn);
            } else {
              slideSlider(btn);
            }
            updateAtcState();
          });
          row.appendChild(btn);
        });

        // If a color is pre-selected, place slider instantly (no animation)
        const preSelected = row.querySelector('.sg-qv__color-btn.is-selected');
        if (preSelected) {
          requestAnimationFrame(function () {
            placeSlider(preSelected);
            slider.style.opacity = '1';
            sliderVisible = true;
          });
        }

        group.appendChild(row);
      } else {
        const placeholder = 'Choose your ' + name.toLowerCase();
        let sizeSelected = selectedOptions[name] || null;

        const wrap = document.createElement('div');
        wrap.className = 'sg-qv__size-wrap';

        const trigger = document.createElement('button');
        trigger.type = 'button';
        trigger.className = 'sg-qv__size-trigger';

        const triggerText = document.createElement('span');
        triggerText.className = 'sg-qv__size-trigger-text';
        triggerText.textContent = sizeSelected || placeholder;

        const chevron = document.createElement('span');
        chevron.className = 'sg-qv__size-chevron';
        chevron.innerHTML = '<svg width="15" height="9" viewBox="0 0 15 9" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1.06067 1.06067L7.06067 7.06067L13.0607 1.06067" stroke="black" stroke-width="1.5" stroke-linecap="square"/></svg>';

        trigger.appendChild(triggerText);
        trigger.appendChild(chevron);

        const list = document.createElement('div');
        list.className = 'sg-qv__size-list';
        list.setAttribute('aria-hidden', 'true');

        values.forEach(function (val) {
          const opt = document.createElement('button');
          opt.type = 'button';
          opt.className = 'sg-qv__size-opt';
          opt.textContent = val;
          if (sizeSelected === val) opt.classList.add('is-selected');

          opt.addEventListener('click', function () {
            sizeSelected = val;
            selectedOptions[name] = val;

            triggerText.textContent = val;
            triggerText.classList.add('is-selected');

            list.querySelectorAll('.sg-qv__size-opt').forEach(function (o) {
              o.classList.toggle('is-selected', o.textContent === val);
            });

            closeDropdown();
            updateAtcState();
          });

          list.appendChild(opt);
        });

        function openDropdown() {
          // Show placeholder left-aligned when open
          triggerText.textContent = placeholder;
          triggerText.classList.remove('is-selected');
          wrap.classList.add('is-open');
          list.setAttribute('aria-hidden', 'false');
        }

        function closeDropdown() {
          wrap.classList.remove('is-open');
          list.setAttribute('aria-hidden', 'true');
          // Restore: selected value centered, or placeholder left-aligned
          if (sizeSelected) {
            triggerText.textContent = sizeSelected;
            triggerText.classList.add('is-selected');
          } else {
            triggerText.textContent = placeholder;
            triggerText.classList.remove('is-selected');
          }
        }

        trigger.addEventListener('click', function (e) {
          e.stopPropagation();
          if (wrap.classList.contains('is-open')) {
            closeDropdown();
          } else {
            // Close any other open dropdowns in this modal
            modal.querySelectorAll('.sg-qv__size-wrap.is-open').forEach(function (w) {
              if (w !== wrap) w.classList.remove('is-open');
            });
            openDropdown();
          }
        });

        document.addEventListener('click', function onOutside(e) {
          if (!wrap.contains(e.target)) {
            if (wrap.classList.contains('is-open')) closeDropdown();
          }
        });

        wrap.appendChild(trigger);
        wrap.appendChild(list);
        group.appendChild(wrap);
      }

      elOpts.appendChild(group);
    });
  }

  /* ── Product cache + prefetch ── */
  const productCache = {};

  function fetchProduct(handle) {
    if (productCache[handle]) return productCache[handle];
    productCache[handle] = fetch('/products/' + handle + '.js')
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      });
    return productCache[handle];
  }

  function prefetchAll() {
    grid.querySelectorAll('.sg__pin[data-handle]').forEach(function (pin) {
      fetchProduct(pin.dataset.handle);
    });
  }

  // Prefetch when section is 400px away from entering the viewport
  const prefetchObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (!entry.isIntersecting) return;
      prefetchAll();
      prefetchObserver.disconnect();
    });
  }, { rootMargin: '400px 0px' });
  prefetchObserver.observe(sgSection);

  function populateModal(product) {
    currentProduct = product;
    selectedOptions = {};

    elTitle.textContent = product.title;
    elPrice.textContent = formatMoney(product.price);

    const rawDesc = product.description || '';
    const tmp = document.createElement('div');
    tmp.innerHTML = rawDesc;
    elDesc.textContent = tmp.textContent || tmp.innerText || '';

    if (product.featured_image) {
      elImg.src = product.featured_image;
      elImg.alt = product.title;
    }

    try { renderOptions(); } catch (e) { console.warn('[SG] renderOptions error:', e); }
    try { updateAtcState(); } catch (e) { console.warn('[SG] updateAtcState error:', e); }
  }

  function openModal(handle) {
    selectedOptions = {};
    currentProduct = null;
    currentVariant = null;

    // If already cached, populate before opening so there's no height jump
    const cached = productCache[handle];
    const isResolved = cached && typeof cached.then !== 'function';

    if (isResolved) {
      populateModal(cached);
    } else {
      elAtc.disabled = true;
      elAtcLbl.textContent = 'ADD TO CART';
      elImg.src = '';
      elTitle.textContent = '';
      elPrice.textContent = '';
      elDesc.textContent = '';
      elOpts.innerHTML = '';
    }

    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';

    // Resolve promise (either fresh fetch or already-in-flight prefetch)
    fetchProduct(handle)
      .then(function (product) {
        // Store resolved value directly so next open is synchronous
        productCache[handle] = product;
        populateModal(product);
      })
      .catch(function (err) {
        console.error('[SG] Failed to load product:', err);
        if (!elTitle.textContent) elTitle.textContent = 'Unable to load product.';
      });
  }

  function closeModal() {
    if (!modal.classList.contains('is-open')) return;
    modal.classList.add('is-closing');

    // Wait for exit animations (0.22s) then clean up
    setTimeout(function () {
      modal.classList.remove('is-open', 'is-closing');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      currentProduct = null;
      selectedOptions = {};
      currentVariant = null;
    }, 240);
  }

  /* ── Add to cart ── */
  elAtc.addEventListener('click', function () {
    if (!currentVariant || elAtc.disabled) return;
    elAtc.disabled = true;
    elAtcLbl.textContent = 'ADDING…';

    // Build items array — always includes the selected variant
    var items = [{ id: currentVariant.id, quantity: 1 }];

    // Auto-bundle: when both the trigger colour and size match, silently add
    // the configured bundle variant alongside the selected product variant.
    if (bundleVariantId) {
      var optionValues = Object.values(selectedOptions).map(function (v) {
        return v.toLowerCase().trim();
      });

      // Fuzzy match so "M" matches "medium" and vice-versa (starts-with comparison).
      function fuzzyMatch(trigger, values) {
        if (!trigger) return true;
        return values.some(function (v) {
          return v === trigger || v.indexOf(trigger) === 0 || trigger.indexOf(v) === 0;
        });
      }

      var colorMatch = fuzzyMatch(bundleTriggerColor, optionValues);
      var sizeMatch  = fuzzyMatch(bundleTriggerSize,  optionValues);

      if (colorMatch && sizeMatch) {
        items.push({ id: parseInt(bundleVariantId, 10), quantity: 1 });
      }
    }

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: items })
    })
      .then(function (r) { return r.json(); })
      .then(function () {
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        elAtcLbl.textContent = 'ADDED!';

        setTimeout(function () {
          if (redirectToCart) {
            window.location.href = '/cart';
          } else {
            closeModal();
          }
        }, 700);
      })
      .catch(function () {
        elAtcLbl.textContent = 'ADD TO CART';
        elAtc.disabled = false;
      });
  });

  /* ── Event listeners ── */
  grid.addEventListener('click', function (e) {
    const pin = e.target.closest('.sg__pin[data-handle]');
    if (!pin) return;
    openModal(pin.dataset.handle);
  });

  modal.querySelector('.sg-qv__close').addEventListener('click', closeModal);
  modal.querySelector('.sg-qv__backdrop').addEventListener('click', closeModal);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });
})();
</script>

